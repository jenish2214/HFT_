# Vercel / local frontend — copy to .env.local for development
#
# After deploying backend to Render, set NEXT_PUBLIC_API_URL to your Render URL:
#   https://hft-api.onrender.com

NEXT_PUBLIC_API_URL=http://localhost:8000

# Optional WebSocket (Render supports wss://)
# NEXT_PUBLIC_USE_WS=1
# NEXT_PUBLIC_WS_URL=wss://hft-api.onrender.com/ws
