# Local development — copy to .env.local
# API calls use /api proxy → http://127.0.0.1:8000 (see next.config.js)

# Optional: override proxy target for `next dev`
# API_URL=http://127.0.0.1:8000

# Production (Vercel): set API_URL to your Render backend (no NEXT_PUBLIC_ needed)
# API_URL=https://hft-api.onrender.com

# Production (Render dashboard): wired automatically via render.yaml fromService

# Optional: direct public API URL instead of /api proxy
# NEXT_PUBLIC_API_URL=https://hft-api.onrender.com

# Optional WebSocket (live streaming instead of polling)
# NEXT_PUBLIC_USE_WS=1
# NEXT_PUBLIC_WS_URL=wss://hft-api.onrender.com/ws
