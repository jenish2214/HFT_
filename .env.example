# Backend (Render / local Docker / manual API start)
HFT_SYMBOL=AAPL
HFT_DEMO=1
HFT_ENGINE_HOST=127.0.0.1
HFT_ENGINE_PORT=9001
# Comma-separated dashboard origins allowed to call the API directly (CORS)
